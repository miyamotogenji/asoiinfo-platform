APP_NAME="ASOIINFO Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Guayaquil
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_EC

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=asoiinfo_db
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=asoiinfo_

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@asoiinfo.com"
MAIL_FROM_NAME="ASOIINFO Platform"

# WhatsApp Business API (Meta)
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=your_permanent_token_here
WHATSAPP_VERIFY_TOKEN=asoiinfo_webhook_verify_2026
WHATSAPP_PHONE_NUMBER_ID_1=your_phone_number_id_1
WHATSAPP_PHONE_NUMBER_ID_2=your_phone_number_id_2

# Spartha POS Integration
SPARTHA_API_URL=https://api.spartha.com
SPARTHA_API_KEY=your_spartha_api_key

# Payment Gateway (optional)
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# PDF
DOMPDF_PAPER_SIZE=A4
